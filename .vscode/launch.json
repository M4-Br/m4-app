    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "Flutter-Android-master",
            "request": "launch",
            "type": "dart",
            "args": [
                "--no-enable-impeller"
            ]
        },
        {
            "name": "Flutter-Android-master (profile mode)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--no-enable-impeller"
            ],
            "flutterMode": "profile"
        },
        {
            "name": "Flutter-Android-master (release mode)",
            "request": "launch",
            "type": "dart",
            "args": [
                "--no-enable-impeller"
            ],
            "flutterMode": "release"
        }
    ]
}